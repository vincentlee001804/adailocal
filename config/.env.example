# Environment Variables Template
# Copy this file to .env and fill in your actual values

# ---------------------------------------------------------------------------
# 1. Feishu Webhook Configuration (Primary Push Method)
# ---------------------------------------------------------------------------
# At least one webhook is required if not using Custom App API.
FEISHU_WEBHOOK_URL=
# Optional secondary/tertiary webhooks to push to multiple groups:
FEISHU_WEBHOOK_URL_2=
FEISHU_WEBHOOK_URL_3=
# Optional: Feishu Webhook signature verification secret
FEISHU_WEBHOOK_SECRET=
# Set to 1 to run a webhook connection test on startup (default: 0)
TEST_WEBHOOKS=0

# ---------------------------------------------------------------------------
# 2. Feishu App Credentials (Alternative Push Method / Bitable logging)
# ---------------------------------------------------------------------------
# Set to 1 to use custom app API to push messages instead of webhooks (default: 0)
USE_APP_API=0
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_CHAT_ID=

# ---------------------------------------------------------------------------
# 3. Feishu Bitable Logging Configuration (Optional)
# ---------------------------------------------------------------------------
# Requires FEISHU_APP_ID and FEISHU_APP_SECRET to be configured as well
BITABLE_APP_TOKEN=
BITABLE_TABLE_ID=

# ---------------------------------------------------------------------------
# 4. AI Summary / Translation Configuration
# ---------------------------------------------------------------------------
# Set to 1 to enable AI-powered summaries and translation to Chinese (default: 0)
USE_AI_SUMMARY=1

# Google Gemini API Key
GEMINI_API_KEY=

# Xiaomi MiMo LLM API Configuration
MIMO_API_KEY=
MIMO_API_BASE=https://api.xiaomimimo.com/v1
MIMO_MODEL=mimo-v2.5

# ---------------------------------------------------------------------------
# 5. Deduplication & Story Similarity Settings
# ---------------------------------------------------------------------------
# File paths for saving tracking data (defaults will be used if left blank)
SENT_NEWS_PATH=logs/sent_news.txt
SENT_STORIES_PATH=logs/sent_stories.jsonl

# Deduplication sliding window in hours (default: 48)
DEDUP_WINDOW_HOURS=48
# Cosine similarity threshold for skipping similar titles (default: 0.60)
SIM_TITLE_THRESHOLD=0.60
# Minimum title length required to run similarity check (default: 8)
MIN_TITLE_LEN_FOR_SIM=8

# Optional: JSON string containing custom brand/keyword translations
# Example: {"Xiaomi": "小米", "Redmi": "红米"}
CHINESE_NAME_MAP=

# ---------------------------------------------------------------------------
# 6. Crawler & Bot Behavior Configuration
# ---------------------------------------------------------------------------
# Skip RSS feeds from rss.app domain (default: 1)
DISABLE_RSS_APP=1
# Limit news search to items published within the last N hours (default: 6)
RECENT_NEWS_HOURS=6
# Max news items pushed per search cycle (default: 1)
MAX_PUSH_PER_CYCLE=1
# Delay in seconds between sending individual messages (default: 1.0)
SEND_INTERVAL_SEC=1.0
# Check interval in seconds between loops (default: 600)
COLLECT_INTERVAL_SEC=600
# Run a single cycle and exit (default: 0)
ONE_SHOT=1

# ---------------------------------------------------------------------------
# 7. Deployment / Leader Election Settings
# ---------------------------------------------------------------------------
# Disable leader election locking (set to 1 to run instantly on local dev, default: 0)
DISABLE_LEADER_ELECTION=1
